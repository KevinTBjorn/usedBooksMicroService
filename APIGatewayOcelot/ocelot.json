{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/register",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "authservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/auth/register",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/auth/login",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "authservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/auth/login",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/auth/logout",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "authservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/auth/logout",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/AddBook/preview",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "addbookservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/store/listings/preview",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/AddBook",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "addbookservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/store/listings",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ],

      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "AddHeadersToRequest": {
        "X-User-Id": "Claims[http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier]",
        "X-User-Email": "Claims[http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress]"
      }
    },
    {
      "DownstreamPathTemplate": "/warehouse/bookspaginationnew",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "warehouseservice",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/store/books",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/warehouse/userbooks/{bookId}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "warehouseservice",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/store/userbooks/{bookId}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/warehouse/userbooks/user/{userId}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "warehouseservice",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/store/userbooks/user/{userId}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/search",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "searchservice",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/search",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5139"
  }
}
